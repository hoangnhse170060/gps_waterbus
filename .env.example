PORT=5177

# Neon / PostgreSQL (bắt buộc trên Railway)
DATABASE_URL=

# Simulator
DEFAULT_SPEED_KMH=16
# true = lấy phút lịch Saigon Waterbus khi khớp cặp bến (vd ST-TD→ST-TD2 = 12p)
PREFER_WATERBUS_SCHEDULE=true
SEND_INTERVAL_MS=2000
DB_REFRESH_MS=15000
# Poll status tàu từ Neon (ms) — cập nhật Active/Bảo trì là Live nhận ~2s
BOAT_STATUS_POLL_MS=2000
USE_FALLBACK_WHEN_EMPTY=true
# false = không POST tàu live (tránh lỗi 400); chỉ gửi khi survey
PUBLISH_LIVE_BOATS=false

# Azure Waterbus BE
TARGET_GPS_ENDPOINT=https://YOUR-APP.azurewebsites.net/api/tracking/locations
TARGET_GPS_API_KEY=
TARGET_GPS_ALLOW_SELF_SIGNED=true
SEND_TO_TARGET=true
# Local: false = chỉ đọc vị trí Azure (Railway ghi). Railway tự ON nhờ RAILWAY_ENVIRONMENT.
# LIVE_AZURE_WRITE=false
# SignalR hub (Azure). Để trống = tự suy từ TARGET_GPS_ENDPOINT → {root}/hubs/tracking
# Server Node nối hub (relay SSE) — tránh CORS từ Railway FE.
# SIGNALR_BROWSER_CONNECT=true chỉ khi Azure đã mở CORS cho domain FE.
SIGNALR_HUB_URL=
SIGNALR_INCIDENTS_HUB_URL=
SIGNALR_BROWSER_CONNECT=false
# JWT (tuỳ chọn). Không cần nếu dùng webhook bên dưới.
TARGET_BEARER_TOKEN=
INCIDENTS_POLL_MS=8000
# Secret chung BE ↔ GPS. Production: chỉ BE gọi hook (FE không giữ secret).
# Header: X-Live-Hook-Secret: <cùng giá trị>
# POST /api/incidents/hook
# Events: IncidentCreated | RescueDispatched | IncidentResolved
# RescueDispatched body: rescueBoatCode (SOS) + optional replacementBoatCode + lat/lng
# Khi kéo về bến xong GPS callback BE:
# POST {apiRoot}/api/incidents/rescue-mission-completed (+ cùng X-Live-Hook-Secret)
# Trip lịch: GET /api/gps/trips/due + POST /api/gps/trips/{tripId}/complete (cùng secret)
LIVE_HOOK_SECRET=
# Override path callback (mặc định /api/incidents/rescue-mission-completed)
# RESCUE_COMPLETED_PATH=/api/incidents/rescue-mission-completed
# Trip theo lịch BE (GPS tự poll due → chạy geometry → locations+tripId → complete)
# LIVE_HOOK_SECRET phải khớp App Setting trên Azure BE (không tự đặt khác local).
TRIP_AUTORUN=true
TRIP_DUE_POLL_MS=30000
# Khi BE trả 401/403: tạm dừng poll (ms) thay vì spam API log
TRIP_DUE_AUTH_BACKOFF_MS=600000
TRIP_GPS_INTERVAL_MS=1000
TRIP_LOOKAHEAD_MINUTES=120
# TRIP_DUE_PATH=/api/gps/trips/due
# TRIP_COMPLETE_PATH=/api/gps/trips/{tripId}/complete
# TRIP_STOP_EVENT_PATH=/api/gps/trips/{tripId}/stops/{stationId}/event
# false/empty = bám đúng đường đã vẽ (routeGeometry). true = ép lên OSM river corridor.
# TRIP_SNAP_TO_RIVER=false
# Tự chạy tàu cứu tới hiện trường, rồi kéo cả hai tàu về bến gần nhất.
# Mỗi bước đều POST lên Azure Tracking với sequence riêng của từng tàu.
RESCUE_GPS_INTERVAL_MS=2000
RESCUE_SPEED_KMH=16
RESCUE_ARRIVE_METERS=15
# Khoảng cách 2 tàu khi cập bến (mét) — tránh chồng rồi cluster nhảy chỗ.
TOW_BERTH_GAP_METERS=12
TOW_ROPE_METERS=18
# Marker live biến mất nếu không còn GPS ping (ms)
HUB_BOAT_TTL_MS=45000
# Poll GET /api/tracking/boats/latest (fallback khi SignalR thiếu) — ms
BOATS_LATEST_POLL_MS=4000
# Trần tốc độ gửi Azure from-gps / locations (tránh 400 khi boat max 200)
AZURE_MAX_SPEED_KMH=80
# true = bỏ tripId/routeCode trên locations (nếu BE còn 400). Mặc định false = gửi đủ theo contract.
# AZURE_GPS_STRIP_TRIP_ON_LOCATION=false
# Trần tốc độ trip trên sông (mặc định = AZURE_MAX_SPEED_KMH)
# TRIP_MAX_SPEED_KMH=32
# false = gửi estimatedDurationMin/standardTravelMin int ≥ 1 lên BE (tránh 400)
# true = gửi phút thập phân đúng panel (vd 0.28) — chỉ khi BE đã hỗ trợ
AZURE_EXACT_TRAVEL_MIN=false
# Device fallback khi tàu chưa có dòng gps_devices
SURVEY_DEVICE_ID=gps-wb-001
# true = mỗi lần refresh DB, tàu Active chưa có gps_devices sẽ tự được đăng ký
AUTO_REGISTER_GPS_DEVICES=true
# Đăng ký thủ công hàng loạt: node scripts/register-gps-devices.mjs
