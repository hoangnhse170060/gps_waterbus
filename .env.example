PORT=5177

# Neon / PostgreSQL (ưu tiên DATABASE_URL)
DATABASE_URL=

# Fallback nếu không dùng DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=waterbusdb
DB_USER=postgres
DB_PASSWORD=

# Simulator
DEFAULT_SPEED_KMH=16
SEND_INTERVAL_MS=2000
DB_REFRESH_MS=15000
USE_FALLBACK_WHEN_EMPTY=true

# Azure Waterbus BE — endpoint nhận GPS
TARGET_GPS_ENDPOINT=https://YOUR-APP.azurewebsites.net/api/tracking/locations
TARGET_GPS_API_KEY=
TARGET_GPS_ALLOW_SELF_SIGNED=false
SEND_TO_TARGET=true
