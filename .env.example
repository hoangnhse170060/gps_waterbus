PORT=5177

# Optional: full PostgreSQL URL. If set, this has priority over DB_HOST/DB_PORT/etc.
DATABASE_URL=

# Saigon Waterbus database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=waterbusdb
DB_USER=postgres
DB_PASSWORD=12345

# Simulator defaults
DEFAULT_SPEED_KMH=16
SEND_INTERVAL_MS=2000
DB_REFRESH_MS=15000
USE_FALLBACK_WHEN_EMPTY=true

# Optional: BE chinh cua ban se nhan GPS o day.
# Neu de trong, simulator van hien map local nhung khong POST ra ngoai.
TARGET_GPS_ENDPOINT=http://localhost:5212/api/tracking/locations
TARGET_GPS_ALLOW_SELF_SIGNED=false
SEND_TO_TARGET=false
